{
  "name": "node-template",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "description": "Template de démarrage React + TypeScript + Vite : thèmes runtime, i18n FR/EN, PWA, tests (Vitest + Playwright), Storybook, ESLint/Prettier, CI/CD GitHub Actions.",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b",
    "typecheck:watch": "tsc -b --watch",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "clean": "rimraf dist node_modules coverage storybook-static playwright-report .vite test-results .lighthouseci",
    "clean:dist": "rimraf dist coverage storybook-static playwright-report .vite test-results .lighthouseci",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.49.1",
    "@storybook/addon-docs": "^10.5.0",
    "@storybook/react": "^10.5.3",
    "@storybook/react-vite": "^10.5.0",
    "@tailwindcss/postcss": "^4.3.3",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-storybook": "^10.5.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.20",
    "prettier": "^3.9.5",
    "rimraf": "^6.0.1",
    "storybook": "^10.5.3",
    "tailwindcss": "^4.3.2",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
